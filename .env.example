# Firebase Web Config — get from Firebase Console → Project Settings → Your Apps → Web
# Copy this file to .env.local and fill in your values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=lauver-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=lauver-ai
VITE_FIREBASE_STORAGE_BUCKET=lauver-ai.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
